Authorization: Bearer {{waToken}}
Content-Type: application/json

{
  "messaging_product": "whatsapp",
  "recipient_type": "individual",
  "to": "{{waRecipient}}",
  "type": "text",
  "text": {
    "preview_url": false,
    "body": "Hi Love 👋,\n\nYour verification code for Stayafrika is: *847291*\n\nThis code expires in 10 minutes. Do not share it with anyone."
  }
}


### ══════════════════════════════════════════════════════════════════════════
### INVOICES
### ══════════════════════════════════════════════════════════════════════════

### List invoices
GET {{baseUrl}}/invoice
Accept: application/json
Authorization: Bearer {{jwt}}

###
### Get invoice by ID
GET {{baseUrl}}/invoice/23ae52b9-d39a-4c53-9867-ff4125a54a82
Accept: application/json
Authorization: Bearer {{jwt}}

###
### Search invoices
GET {{baseUrl}}/invoice/query?search=mike
Accept: application/json
Authorization: Bearer {{jwt}}

###
### Get invoice overview (pie chart data)
GET {{baseUrl}}/invoice/overview
Accept: application/json
Authorization: Bearer {{jwt}}

###
### Send invoice by email
POST {{baseUrl}}/invoice/send/{{invoiceId}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "emails": ["davidhero125@gmail.com"]
}

###
### Create invoice (multipart/form-data)
POST {{baseUrl}}/invoice
Authorization: Bearer {{jwt}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="title"

Website Development Invoice
--boundary
Content-Disposition: form-data; name="payer_name"

Mike Base
--boundary
Content-Disposition: form-data; name="payer_email"

davidhero125@gmail.com
--boundary
Content-Disposition: form-data; name="country"

NG
--boundary
Content-Disposition: form-data; name="due_date"

2026-03-15
--boundary
Content-Disposition: form-data; name="template_id"

template_001
--boundary
Content-Disposition: form-data; name="service_fee"

1500
--boundary
Content-Disposition: form-data; name="make_default"

false
--boundary
Content-Disposition: form-data; name="note"

thank you for your patronage
--boundary
Content-Disposition: form-data; name="invoice_items"

[{"invoice_type":"per_unit","description":"Design Work","quantity":1,"unit_price":50000,"amount":50000},{"invoice_type":"per_unit","description":"Backend Development","quantity":2,"unit_price":75000,"amount":150000}]
--boundary--


