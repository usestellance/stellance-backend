###
# Create a new comment (authenticated)
POST {{baseUrl}}/comments
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "user_id": "{{userId}}",
  "invoice_id": "{{invoiceId}}",
  "commenter_name": "{{name}}",
  "comment_text": "I love this, we can pay now",
  "commenter_email": "mike@example.com"
}


###
# Create a reply to an existing comment
POST {{baseUrl}}/comments
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "user_id": "{{userId}}",
  "invoice_id": "{{invoiceId}}",
  "commenter_name": "{{name}}",
  "comment_text": "Following up on this invoice.",
  "parent_id": "{{parentCommentId}}"
}


###
GET {{baseUrl}}/comments?invoice_id={{invoiceId}}&page=1&limit=20&sort_order=desc
Accept: application/json
Authorization: Bearer {{jwt}}

###

# returns the comments for an invoice queried with the commentId
GET {{baseUrl}}/comments/{{CommentId}}
Accept: application/json
Authorization: Bearer {{jwt}}

###

# returns the invoice status data for the pie chart
GET {{baseUrl}}/invoice/overview
# query params {month=july} or {month=jul}
Accept: application/json
Authorization: Bearer {{jwt}}

# returns the transaction card data on the overview page
GET {{baseUrl}}/transaction/stats
Accept: application/json
Authorization: Bearer {{jwt}}

# returns the cash inflow data for the line graph on the overview page
GET {{baseUrl}}/transaction/inflow
# query params = {from, to} in YYYY-MM-DD
Accept: application/json
Authorization: Bearer {{jwt}}


### 
# update a comment by the id
PATCH {{baseUrl}}/comments/{{CommentId}}
Accept: application/json
Authorization: Bearer {{jwt}}

{
    "email": "test@frank.com",
    "comment_text": "I think we can bump the charges by 500%"
}

###
POST {{baseUrl}}/invoice/send/{{{invoiceId}}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "emails": [""]
}

###
# still follow the post body from the previous impl, just use form data instead
# and add fields for the template_id(required), logo
POST {{baseUrl}}/invoice
Authorization: Bearer {{jwt}}
Content-Type: multipart/form-data

--boundary
Content-Disposition: form-data; name="title"

Website Development Invoice
--boundary
Content-Disposition: form-data; name="payer_name"

Mike Base
--boundary
Content-Disposition: form-data; name="payer_email"

mike@example.com
--boundary
Content-Disposition: form-data; name="country"

NG
--boundary
Content-Disposition: form-data; name="due_date"

2026-02-15
--boundary
Content-Disposition: form-data; name="template_id"

default
--boundary
Content-Disposition: form-data; name="service_fee"

1500
--boundary
Content-Disposition: form-data; name="make_default"

true
--boundary
Content-Disposition: form-data; name="invoice_items"

{{invoiceItems}}
--boundary
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
--boundary--